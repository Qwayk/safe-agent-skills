{
  "ok": true,
  "operation": "place-actions.locations.place-action-links.list",
  "request": {
    "method": "GET",
    "host": "https://mybusinessplaceactions.googleapis.com",
    "path": "v1/locations/abc/placeActionLinks",
    "params": {
      "filter": "placeActionType=DINING_RESERVATION",
      "pageSize": 20,
      "pageToken": "page-token-1"
    }
  },
  "response": {
    "placeActionLinks": [
      {
        "name": "locations/abc/placeActionLinks/xyz",
        "uri": "https://example.com/reserve",
        "placeActionType": "DINING_RESERVATION",
        "isPreferred": true
      }
    ]
  }
}
